# SAMRAKSHA Environment Configuration
# Copy this file to .env and update with your actual values

# Database
DATABASE_URL=postgresql+asyncpg://samraksha:samraksha_secret@postgres:5432/samraksha

# Redis Cache
REDIS_URL=redis://redis:6379/0

# API Configuration
ENVIRONMENT=development
SECRET_KEY=samraksha-super-secret-jwt-key-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Demo Mode (set to false in production)
DEMO_MODE=true

# Demo Credentials
DEMO_SEED_PASSWORD=password123
ADMIN_SEED_PASSWORD=password123

# Optional: Email Configuration (if implementing email features)
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# Optional: File Upload Configuration
# UPLOAD_DIR=/app/uploads
# MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Optional: Logging
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/samraksha/app.log
