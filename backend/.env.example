# Database
DB_USER=samraksha_user
DB_PASSWORD=change_this_strong_password
DB_NAME=samraksha
DATABASE_URL=postgresql+asyncpg://samraksha_user:change_this_strong_password@postgres/samraksha

# Security
SECRET_KEY=generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Redis (rate limiting + WebSocket state)
REDIS_URL=redis://redis:6379

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=10
DEMO_MODE=true

# CCTV
CCTV_FRAME_INTERVAL_SEC=2
CCTV_LOITERING_THRESHOLD_FRAMES=300
CCTV_ANOMALY_ZSCORE_THRESHOLD=2.5

# Indian Kanoon (Optional)
INDIAN_KANOON_TOKEN=
