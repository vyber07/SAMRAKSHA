FROM node:20-alpine

WORKDIR /app

# Copy package.json and package-lock.json first to leverage Docker cache
COPY package*.json ./

RUN npm install

# Copy all source files
COPY . .

# Expose port 80
EXPOSE 80

# Start Vite dev server on port 80
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "80"]
